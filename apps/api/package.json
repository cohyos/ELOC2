    "@eloc2/eo-investigation": "workspace:*",
    "@eloc2/eo-management": "workspace:*",
    "@eloc2/eo-tasking": "workspace:*",
    "@eloc2/events": "workspace:*",
    "@eloc2/fusion-core": "workspace:*",
    "@eloc2/geometry": "workspace:*",
    "@eloc2/projections": "workspace:*",
    "@eloc2/registration": "workspace:*",
    "@eloc2/scenario-library": "workspace:*",
    "@eloc2/shared-utils": "workspace:*",
    "@eloc2/simulator": "workspace:*",
    "@fastify/static": "^9.0.0",
